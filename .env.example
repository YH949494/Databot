APP_ENV=production
LOG_LEVEL=INFO
TZ=Asia/Kuala_Lumpur

MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority
MONGODB_DB_NAME=apreferral

TG_GROWTH_BOT_TOKEN=<telegram_bot_token>
TG_REPORT_CHAT_ID=-1001234567890
TG_ADMIN_USER_IDS=123456789,987654321
TG_CHANNEL_ID=-1001234567890

# Source-of-truth collections
REFERRAL_EVENTS_COLLECT_ION=referral_events
REFERRAL_KPI_COLLECTION=referral_kpis
USER_COLLECTION=users
CLAIM_EVENTS_COLLECTION=claim_events
POST_LOG_COLLECTION=post_logs
CHANNEL_EVENTS_COLLECTION=channel_events
# NEW: stores getChatStatistics + getMessageStatistics snapshots
CHANNEL_STATS_OVERVIEW_COLLECTION=channel_stats_overview

# Derived collections
DERIVED_REFERRAL_DAILY_COLLECTION=referral_daily_summary
DERIVED_REFERRAL_WEEKLY_COLLECTION=referral_weekly_summary
DERIVED_CHANNEL_DAILY_COLLECTION=channel_daily_summary
DERIVED_CONTENT_DAILY_COLLECT_ION=content_daily_summary
DERIVED_INVITER_DAILY_COLLECTION=referral_inviter_stats_daily
DERIVED_USER_PROFILE_COLLECT_ION=user_profile_summary
DERIVED_SEGMENTATION_KPIS_COLLECTION=segmentation_daily_kpis

SCHEDULER_ENABLED=true
SCHEDULE_DAILY_CRON=10 0 * * *
SCHEDULE_WEEKY_CRON=20 0 * * 1
