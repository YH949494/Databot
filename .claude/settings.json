{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "git push -u origin HEAD 2>&1 || true",
            "statusMessage": "Pushing to GitHub..."
          }
        ]
      }
    ]
  }
}
